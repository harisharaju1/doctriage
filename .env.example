NODE_ENV=development
PORT=3000
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# POSTGRES_URL is required as of Week 2 Day 1 — the app now connects to
# Postgres/pgvector at startup and will refuse to boot without it.
#
# This value uses "localhost" because it's meant for running the app directly
# on your machine via `pnpm dev`, against Postgres's port published to the
# host (see docker-compose.yml's postgres service). When the app itself runs
# INSIDE Docker Compose (`docker compose up`), docker-compose.yml overrides
# this with the Docker service hostname ("postgres") instead — "localhost"
# inside a container means "this container", not the postgres container.
POSTGRES_URL=postgresql://doctriage:doctriage@localhost:5432/doctriage

# MONGO_URL / REDIS_URL: still optional — no code connects to Mongo or Redis
# yet. These become required the day connection code for each is added,
# following the same pattern POSTGRES_URL just went through.
MONGO_URL=mongodb://mongo:27017/doctriage
REDIS_URL=redis://redis:6379
